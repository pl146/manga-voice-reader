{
  "_comment": "Common manga OCR misreads. Keys are wrong text, values are corrections. Case-insensitive matching is done in code.",
  "word_corrections": {
    "ca/ed": "called",
    "contro/": "control",
    "ki/": "kill",
    "ki/ed": "killed",
    "ki/er": "killer",
    "ki/ing": "killing",
    "wi/": "will",
    "te/": "tell",
    "te/ing": "telling",
    "a/": "all",
    "fa/": "fall",
    "fa/en": "fallen",
    "he/o": "hello",
    "he/p": "help",
    "fo/ow": "follow",
    "sti/": "still",
    "fu/": "full",
    "bu/et": "bullet",
    "sku/": "skull",
    "spe/": "spell",
    "we/": "well",
    "wa/": "wall",
    "ba/": "ball",
    "sma/": "small",
    "ta/": "tall",
    "pu/": "pull",
    "ro/": "roll",
    "tro/": "troll",
    "actua/y": "actually",
    "rea/y": "really",
    "fina/y": "finally",
    "usua/y": "usually",
    "norma/y": "normally",
    "tota/y": "totally",
    "basica/y": "basically",
    "il/usion": "illusion",
    "il/egal": "illegal",
    "vi/age": "village",
    "vi/ain": "villain",
    "inte/igent": "intelligent",
    "mi/ion": "million",
    "bi/ion": "billion",
    "co/ect": "collect",
    "a/ow": "allow",
    "fo/owing": "following",
    "be/ieve": "believe"
  },
  "pattern_corrections": [
    {
      "_comment": "Slash between letters -> l (generic fallback)",
      "pattern": "([a-zA-Z])/([a-zA-Z])",
      "replacement": "\\1l\\2"
    },
    {
      "_comment": "Trailing slash after letters -> l",
      "pattern": "([a-zA-Z])/$",
      "replacement": "\\1l"
    },
    {
      "_comment": "Pipe as l: ki|l -> kill",
      "pattern": "([a-zA-Z])\\|([a-zA-Z])",
      "replacement": "\\1l\\2"
    },
    {
      "_comment": "Zero as O in words",
      "pattern": "(?<=[A-Za-z])0(?=[A-Za-z])",
      "replacement": "O"
    },
    {
      "_comment": "Leading zero before letters: 0KAY -> OKAY",
      "pattern": "\\b0([A-Z]{2,})",
      "replacement": "O\\1"
    }
  ],
  "common_sfx": {
    "_comment": "Sound effects to normalize for TTS",
    "AAAGH": "Aaagh",
    "GRRR": "Grrr",
    "HAHAHA": "Ha ha ha",
    "BWAHAHA": "Bwa ha ha",
    "WHOOSH": "Whoosh",
    "THUD": "Thud",
    "CRASH": "Crash",
    "BOOM": "Boom",
    "SLASH": "Slash",
    "CLANG": "Clang"
  }
}
